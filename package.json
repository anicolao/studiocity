{
  "name": "studiocity",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite dev --host 127.0.0.1 --port 5173",
    "build": "bun --bun tsc && bun --bun vite build",
    "preview": "bun --bun vite preview --host 127.0.0.1 --port 4173",
    "playwright:install": "bun --bun playwright install --with-deps chromium",
    "test:e2e": "bun --bun playwright test",
    "test:e2e:update-snapshots": "bun --bun playwright test --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.0.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
