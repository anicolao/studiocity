{
  "name": "studiocity",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite dev --host 127.0.0.1 --port 5173",
    "dev:e2e": "VITE_USE_FIREBASE_EMULATORS=true bun --bun vite dev --host 127.0.0.1 --port 5173",
    "dev:e2e:emulated": "node scripts/free-emulator-ports.mjs && bun run build:functions && if [ -f \"$HOME/Downloads/studio-city-service-account.json\" ]; then export GOOGLE_APPLICATION_CREDENTIALS=\"$HOME/Downloads/studio-city-service-account.json\"; fi; firebase emulators:exec --project studiocity-f56c1 --only firestore,functions \"bun run dev:e2e\"",
    "build": "bun --bun vite build",
    "build:functions": "cd functions && bun install --frozen-lockfile && bun run build",
    "preview": "bun --bun vite preview --host 127.0.0.1 --port 4173",
    "playwright:install": "bun --bun playwright install --with-deps chromium",
    "emulators": "firebase emulators:start --only firestore,functions",
    "emulators:exec": "firebase emulators:exec --only firestore,functions",
    "firebase:deploy": "firebase deploy --project studiocity-f56c1 --only firestore:rules,functions",
    "secrets:firebase": "node scripts/set-firebase-secrets.mjs",
    "test:e2e": "bun --bun playwright test",
    "test:e2e:update-snapshots": "bun --bun playwright test --update-snapshots"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "firebase": "^12.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.0.6",
    "firebase-tools": "^15.0.0",
    "svelte": "^5.54.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
